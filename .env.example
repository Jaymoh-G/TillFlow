# Queue: use sync on local machines without a worker; use database (or redis) in staging/production
# and run `php artisan queue:work` (or Supervisor).
QUEUE_CONNECTION=sync

# Activity logs (see config/activity_log.php)
ACTIVITY_LOG_ENABLED=true
# Set false to log each payment once (InvoicePayment subject only; invoice timeline still gets rows via properties->invoice_id where applicable)
ACTIVITY_LOG_DUAL_SUBJECT_INVOICE_PAYMENT=true
ACTIVITY_LOG_RETENTION_DAYS=730
ACTIVITY_LOG_PRUNE_CHUNK=1000

# Web Push (VAPID). Generate keys once (tinker): \Minishlink\WebPush\VAPID::createVapidKeys() — paste publicKey/privateKey here.
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# M-Pesa Daraja (Safaricom) — STK Push for subscription payments
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Full URL must be HTTPS in production; path defaults under APP_URL
# MPESA_STK_CALLBACK_PATH=/api/v1/webhooks/mpesa/stk-callback

# --- Backups (Spatie laravel-backup) — see config/backup.php and docs/BACKUP.md
BACKUP_ENABLED=true
BACKUP_INCLUDE_PRIVATE_STORAGE=false
BACKUP_WRITE_S3=false
BACKUP_DESTINATION_S3_DISK=s3_backups
BACKUP_ARCHIVE_PASSWORD=
BACKUP_MAIL_TO=
BACKUP_NOTIFY_SUCCESS_CHANNELS=
BACKUP_NOTIFY_HEALTHY_CHANNELS=
BACKUP_NOTIFY_CLEANUP_CHANNELS=
BACKUP_MONITOR_MAX_AGE_DAYS=2
BACKUP_MONITOR_MAX_STORAGE_MB=50000
BACKUP_KEEP_ALL_DAYS=60
BACKUP_KEEP_DAILY_DAYS=0
BACKUP_KEEP_WEEKLY_WEEKS=0
BACKUP_KEEP_MONTHLY_MONTHS=0
BACKUP_KEEP_YEARLY_YEARS=0
BACKUP_MAX_TOTAL_MB=
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_DEFAULT_REGION=
BACKUP_AWS_BUCKET=
BACKUP_AWS_URL=
BACKUP_AWS_ENDPOINT=
BACKUP_AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional: email tenant export zips (also set per-tenant ui_settings.backup_email)
TENANT_BACKUP_EMAIL_ENABLED=false
TENANT_BACKUP_EMAIL_FROM=
TENANT_BACKUP_EMAIL_FROM_NAME=

# Platform owner (db:seed --class=PlatformOwnerSeeder). Override password here instead of relying on seeder defaults.
# PLATFORM_OWNER_EMAIL=james.mbatia@breezetech.co.ke
# PLATFORM_OWNER_PASSWORD=
